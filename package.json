{
  "name": "jetgit-plus",
  "displayName": "JetGit Plus - IDEA-style Git Graph & Commit for VS Code",
  "publisher": "strNewBee",
  "description": "JetGit Plus brings an IntelliJ IDEA-style Git workflow to VS Code and Cursor: git graph visualization, IDEA-style commit panel with shelve/stash, branch management, cherry-pick, rebase, merge, 3-way merge editor, and rich context menus.",
  "version": "0.5.2",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/strNewBee/jetgit-plus"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "intellij",
    "jetbrains",
    "idea",
    "git graph",
    "commit",
    "shelf",
    "stash",
    "branch",
    "merge",
    "cherry-pick",
    "rebase",
    "git log",
    "context menu",
    "diff",
    "3-way merge",
    "webstorm",
    "pycharm",
    "goland",
    "rider"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "jetgit-plus-panel",
          "title": "JetGit",
          "icon": "$(git-branch)"
        }
      ],
      "activitybar": [
        {
          "id": "jetgit-plus-commit",
          "title": "Commit",
          "icon": "images/commit-icon.svg"
        }
      ]
    },
    "views": {
      "jetgit-plus-panel": [
        {
          "type": "webview",
          "id": "jetgit-plus.gitLog",
          "name": "Git Log"
        }
      ],
      "jetgit-plus-commit": [
        {
          "type": "webview",
          "id": "jetgit-plus.commitPanel",
          "name": "Commit"
        }
      ]
    },
    "commands": [
      {
        "command": "jetgit-plus.refreshLog",
        "title": "Refresh Git Log",
        "icon": "$(refresh)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.openMergeEditor",
        "title": "Open Merge Editor",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.openConflicts",
        "title": "Conflicts",
        "icon": "$(git-merge)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.openMergeEditorFromSCM",
        "title": "Open in JetGit Merge Editor",
        "icon": "$(git-merge)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.showFileHistory",
        "title": "(JetGit) Show File History",
        "icon": "$(history)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.nextDiff",
        "title": "Next File Diff",
        "icon": "$(arrow-down)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.prevDiff",
        "title": "Previous File Diff",
        "icon": "$(arrow-up)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.commitPanel.refresh",
        "title": "Refresh Changes",
        "icon": "$(refresh)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.commitPanel.commit",
        "title": "Commit",
        "icon": "$(check)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.commitPanel.commitAndPush",
        "title": "Commit and Push",
        "icon": "$(cloud-upload)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.commitPanel.shelve",
        "title": "Shelve Changes",
        "icon": "$(archive)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.commitPanel.unshelve",
        "title": "Unshelve Changes",
        "icon": "$(package)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.openPushPanel",
        "title": "Push...",
        "icon": "$(cloud-upload)",
        "category": "JetGit"
      },
      {
        "command": "jetgit-plus.editSource",
        "title": "(JetGit) Edit Source",
        "icon": "$(go-to-file)",
        "category": "JetGit"
      }
    ],
    "menus": {
      "view/title": [],
      "scm/title": [
        {
          "command": "jetgit-plus.openConflicts",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "jetgit-plus.openMergeEditorFromSCM",
          "when": "scmProvider == git && scmResourceGroup == merge",
          "group": "inline@10"
        }
      ],
      "editor/context": [
        {
          "command": "jetgit-plus.showFileHistory",
          "when": "editorTextFocus",
          "group": "git@1"
        },
        {
          "command": "jetgit-plus.editSource",
          "when": "isInDiffEditor && resourceScheme != file",
          "group": "git@2"
        }
      ],
      "explorer/context": [
        {
          "command": "jetgit-plus.showFileHistory",
          "when": "!explorerResourceIsFolder",
          "group": "git@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "jetgit-plus.openPushPanel",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "jetgit-plus.nextDiff",
        "key": "ctrl+f7",
        "mac": "cmd+f7",
        "when": "editorFocus"
      },
      {
        "command": "jetgit-plus.prevDiff",
        "key": "ctrl+shift+f7",
        "mac": "cmd+shift+f7",
        "when": "editorFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:webview": "cd webview && pnpm run watch",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "vsce:package": "pnpm run package && pnpm run build:web && vsce package --no-dependencies",
    "vsce:publish": "pnpm run package && pnpm run build:web && vsce publish --no-dependencies",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "biome check src webview/src",
    "test": "vscode-test",
    "build:web": "cd webview && pnpm run build",
    "build": "pnpm run compile && pnpm run build:web",
    "dev:web": "cd webview && pnpm run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.2",
    "mocha": "^11.7.6",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd",
  "dependencies": {
    "node-diff3": "^3.2.0"
  }
}
